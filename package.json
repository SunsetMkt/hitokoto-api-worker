{
  "name": "hitokoto-api-worker",
  "version": "1.1.0",
  "description": "Cloudflare Workers implementation of Hitokoto API",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "fetch-sentences": "node scripts/fetch-sentences.mjs",
    "pack-sentences": "node scripts/pack-sentences.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "ncu": "npm-check-updates",
    "ncu:fix": "npm-check-updates -u"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SunsetMkt/hitokoto-api-worker.git"
  },
  "keywords": [
    "hitokoto",
    "cloudflare",
    "workers"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SunsetMkt/hitokoto-api-worker/issues"
  },
  "homepage": "https://github.com/SunsetMkt/hitokoto-api-worker#readme",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260507.1",
    "npm-check-updates": "^22.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.88.0"
  },
  "dependencies": {
    "msgpackr": "^2.0.1"
  }
}
